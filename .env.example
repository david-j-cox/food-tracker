# Fly.io sets DATABASE_URL automatically for attached Postgres
DATABASE_URL=postgresql://user:password@localhost:5432/food_tracker

# Flask session signing key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me

# PIN for user login (simple numeric or alphanumeric)
FOOD_TRACKER_PIN=change-me

# API key for the sync endpoint (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FOOD_TRACKER_API_KEY=change-me

# Anthropic API key for Claude Vision (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# USDA FoodData Central API key (from fdc.nal.usda.gov/api-key-signup.html)
USDA_API_KEY=change-me

# Ntfy topic name for push notifications (pick a unique private name)
NTFY_TOPIC=change-me
